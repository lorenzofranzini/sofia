body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    background-color: #282c34;
    color: #ffffff;
    font-family: Arial, sans-serif;
}

h1 {
    margin-bottom: 20px;
    font-size: 2.5em;
}

canvas {
    background-color: #000000;
    border: 2px solid #ffffff;
}
